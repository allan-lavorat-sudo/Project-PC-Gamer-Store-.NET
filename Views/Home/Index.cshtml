@model IEnumerable<Project_NexoGamer_Store.Models.Product>

@{
    ViewData["Title"] = "Store";
}

<div class="hero-section">
    <div class="container text-center">
        <h1 class="display-1 fw-bold main-title">NEXO<span class="text-accent">GAMER</span></h1>
        <p class="lead subtitle">Upgrade your reality with the ultimate gaming machines.</p>
    </div>
</div>

<div class="container my-5">
    <div class="row g-4">
        @foreach (var product in Model)
        {
            <div class="col-md-4">
                <div class="card h-100 product-card">
                    <div class="image-container">
                        <img src="@product.ImageUrl" class="card-img-top" alt="@product.Name">
                    </div>
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title fw-bold">@product.Name</h5>
                        <p class="card-text text-muted flex-grow-1">@product.Description</p>
                        <div class="d-flex justify-content-between align-items-center mt-3">
                            <span class="price-tag h4 mb-0">$@product.Price</span>
                            <a asp-action="Details" asp-route-id="@product.Id" class="btn btn-description">Description</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
