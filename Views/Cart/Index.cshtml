@model IEnumerable<Project_NexoGamer_Store.Models.Product>

@{
    ViewData["Title"] = "Shopping Cart";
}

<div class="container py-5 mt-5">
    <h1 class="display-5 fw-bold mb-5">Your <span class="text-accent">Cart</span></h1>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-cart-x display-1 text-muted mb-4"></i>
            <h3>Your cart is empty</h3>
            <p class="text-muted">Explore our PCs and add some power to your setup!</p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary rounded-pill px-4 mt-3">Back to Store</a>
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-lg-8">
                @foreach (var item in Model)
                {
                    <div class="card bg-dark border-secondary border-opacity-25 mb-3 rounded-4 p-3">
                        <div class="row align-items-center">
                            <div class="col-3">
                                <img src="@item.ImageUrl" class="img-fluid rounded-3" alt="@item.Name">
                            </div>
                            <div class="col-6">
                                <h5 class="fw-bold mb-1">@item.Name</h5>
                                <div class="text-accent fw-bold">$@item.Price</div>
                            </div>
                            <div class="col-3 text-end">
                                <button class="btn btn-outline-danger btn-sm border-0"><i class="bi bi-trash"></i></button>
                            </div>
                        </div>
                    </div>
                }
            </div>
            <div class="col-lg-4">
                <div class="card bg-dark border-secondary border-opacity-25 rounded-4 p-4 shadow-lg sticky-top" style="top: 100px;">
                    <h4 class="fw-bold mb-4">Summary</h4>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Subtotal</span>
                        <span>$@Model.Sum(p => p.Price)</span>
                    </div>
                    <div class="d-flex justify-content-between mb-3">
                        <span>Shipping</span>
                        <span class="text-accent">FREE</span>
                    </div>
                    <hr class="border-secondary opacity-25">
                    <div class="d-flex justify-content-between mb-4 h4 fw-bold">
                        <span>Total</span>
                        <span class="text-accent">$@Model.Sum(p => p.Price).ToString("F2")</span>
                    </div>
                    <a asp-action="Checkout" class="btn btn-primary btn-lg w-100 rounded-pill fw-bold py-3 shadow-lg">CHECKOUT</a>
                </div>
            </div>
        </div>
    }
</div>
